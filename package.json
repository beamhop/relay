{
  "name": "beamhop-relay-v2",
  "version": "0.1.0",
  "description": "A Bun/TypeScript Nostr relay with pluggable NIP support and optional SQLite persistence.",
  "type": "module",
  "private": true,
  "bin": {
    "beamhop-relay": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
